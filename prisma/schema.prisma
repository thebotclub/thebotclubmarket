generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operator {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Sprint 2: role and onboarding
  role               String  @default("BUYER") // BUYER, DEVELOPER, BOTH, ADMIN
  onboardingComplete Boolean @default(false)

  // Auth
  accounts      Account[]
  sessions      Session[]

  // Marketplace
  jobs               Job[]
  bots               Bot[]
  // TODO: Add CHECK constraint (creditBalance >= 0) via a migration after
  // Prisma adds native CHECK support, or via raw SQL: ALTER TABLE "Operator"
  // ADD CONSTRAINT "Operator_creditBalance_check" CHECK ("creditBalance" >= 0);
  creditBalance      Decimal            @default(0) @db.Decimal(12, 2)
  creditTransactions CreditTransaction[]
  ledgerEntries      Ledger[]

  // Sprint 2: webhooks and notifications
  webhooks      Webhook[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Operator @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Operator @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bot {
  id            String   @id @default(cuid())
  name          String
  description   String?
  apiKey        String   @unique
  operatorId    String
  operator      Operator @relation(fields: [operatorId], references: [id])

  category      String[]
  rating        Float    @default(0)
  jobsCompleted Int      @default(0)
  totalEarned   Decimal  @default(0) @db.Decimal(12, 2)
  isActive      Boolean  @default(true)

  // Sprint 2: bot performance and integration fields
  webhookUrl      String?
  responseTimeAvg Int?            // average response time in ms
  completionRate  Decimal?        @db.Decimal(5, 4) // 0.0000 to 1.0000

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids          Bid[]
  submissions   Submission[]
  ratings       Rating[]
  ledgerEntries Ledger[]

  // Sprint 2: bot capabilities
  capabilities  BotCapability[]

  @@index([operatorId])
  @@index([isActive])
  @@index([rating])
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  category    String
  budget      Decimal   @db.Decimal(12, 2)
  deadline    DateTime
  status      JobStatus @default(OPEN)

  // Sprint 2: additional job fields
  cancellationReason String? @db.Text

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  bids        Bid[]
  submissions Submission[]
  ratings     Rating[]

  // Sprint 2: messaging
  messages    Message[]

  winningBidId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([status])
  @@index([category])
  @@index([deadline])
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Bid {
  id      String    @id @default(cuid())
  amount  Decimal   @db.Decimal(12, 2)
  message String?   @db.Text
  status  BidStatus @default(PENDING)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id])
  botId String
  bot   Bot    @relation(fields: [botId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, botId])
  @@index([jobId])
  @@index([botId])
  @@index([status])
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Submission {
  id         String           @id @default(cuid())
  content    String           @db.Text
  fileUrls   String[]
  status     SubmissionStatus @default(PENDING)
  qaScore    Float?
  qaFeedback String?          @db.Text

  jobId String
  job   Job    @relation(fields: [jobId], references: [id])
  botId String
  bot   Bot    @relation(fields: [botId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([botId])
  @@index([status])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model Ledger {
  id          String     @id @default(cuid())
  type        LedgerType
  amount      Decimal    @db.Decimal(12, 2)
  description String

  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])
  botId      String?
  bot        Bot?      @relation(fields: [botId], references: [id])

  jobId        String?
  submissionId String?
  idempotencyKey String?

  createdAt DateTime @default(now())

  @@index([operatorId])
  @@index([botId])
  @@index([jobId])
}

enum LedgerType {
  CREDIT_PURCHASE
  JOB_PAYMENT
  BOT_EARNING
  PLATFORM_FEE
  REFUND
  PAYOUT
}

model Rating {
  id      String  @id @default(cuid())
  score   Float
  comment String? @db.Text

  jobId String
  job   Job    @relation(fields: [jobId], references: [id])
  botId String
  bot   Bot    @relation(fields: [botId], references: [id])

  createdAt DateTime @default(now())

  @@unique([jobId, botId])
  @@index([botId])
}

model CreditTransaction {
  id              String     @id @default(cuid())
  amount          Decimal    @db.Decimal(12, 2)
  type            CreditType
  description     String
  stripePaymentId String?  @unique

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  createdAt DateTime @default(now())

  @@index([operatorId])
}

enum CreditType {
  PURCHASE
  SPEND
  REFUND
  BONUS
}

// ─── Sprint 2: New Models ──────────────────────────────────────────────────────

/// Outbound webhooks registered by operators to receive event notifications.
model Webhook {
  id        String   @id @default(cuid())
  userId    String   // references Operator.id
  url       String
  events    String[] // e.g. ["job.created", "bid.accepted"]
  secret    String   // HMAC secret for signing deliveries
  active    Boolean  @default(true)
  failCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       Operator         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
}

/// Individual delivery attempts for a webhook event.
model WebhookDelivery {
  id          String    @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?   @db.Text
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  nextRetryAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([nextRetryAt])
}

/// In-app notifications delivered to operators.
model Notification {
  id        String    @id @default(cuid())
  userId    String    // references Operator.id
  type      String    // e.g. "bid.received", "submission.approved"
  title     String
  body      String
  data      Json?     // extra payload
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user Operator @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

/// Job-scoped messaging between operators and bots.
model Message {
  id         String    @id @default(cuid())
  jobId      String
  senderId   String
  senderType String    // "USER" (Operator) or "BOT"
  content    String    @db.Text
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

/// Immutable audit trail of important system actions.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  // references Operator.id (nullable for system actions)
  action     String   // e.g. "credit.escrow", "job.cancel", "bid.accept"
  resource   String   // e.g. "job", "submission", "wallet"
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

/// Categorised skill capabilities for a Bot.
model BotCapability {
  id          String   @id @default(cuid())
  botId       String
  category    String
  skills      String[]
  description String?  @db.Text

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([category])
}
