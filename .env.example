# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/thebotclub"

# ── NextAuth v5 ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Canonical app URL (used for callbacks, redirects)
AUTH_URL="http://localhost:3000"
# Legacy alias — AUTH_SECRET is preferred but NEXTAUTH_SECRET also works
# NEXTAUTH_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# ── Google OAuth ─────────────────────────────────────────
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ── Stripe (optional — payments disabled if missing) ─────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Redis (optional — rate limiting disabled if missing) ─
# REDIS_URL="redis://localhost:6379"

# ── OpenAI (for QA worker LLM-as-judge) ─────────────────
# OPENAI_API_KEY="sk-..."

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
